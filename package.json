{
  "name": "family-serve-delicious",
  "version": "2.4.0",
  "description": "A server to manage dietary profiles (preferences, needs, allergies) for a family or group.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/prompts/en src/prompts/es src/prompts/fr dist/prompts/",
    "start": "node dist/index.js",
    "dev": "docker-compose -f docker-compose.dev.yml up -d && echo '🚀 Dev environment started at http://localhost:3000'",
    "stop": "docker-compose down && docker-compose -f docker-compose.dev.yml down",
    "test": "node --no-warnings node_modules/jest/bin/jest.js --config jest.config.js",
    "test:integration": "node --no-warnings node_modules/jest/bin/jest.js --config jest.config.js tests/integration/",
    "test:unit": "node --no-warnings node_modules/jest/bin/jest.js --config jest.config.js tests/unit/",
    "test:security": "node --no-warnings node_modules/jest/bin/jest.js --config jest.config.js tests/security/",
    "setup": "./manage.sh setup",
    "db:start": "docker-compose up -d mongodb",
    "db:stop": "docker-compose stop mongodb",
    "db:gui": "docker-compose up -d mongodb mongo-express && echo '🎯 MongoDB GUI: http://localhost:8081 (see .env)'",
    "prod": "docker-compose up -d && echo '🎯 MCP Server started in production mode'",
    "status": "docker-compose ps",
    "logs": "docker-compose logs -f",
    "logs:app": "docker-compose logs -f family-serve-app",
    "clean": "docker-compose down -v && echo '🧹 All containers and volumes removed'",
    "lm-studio": "./manage.sh lmstudio config",
    "claude": "./manage.sh claude config"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "family",
    "dietary",
    "allergens",
    "preferences",
    "meal-planning",
    "mongodb",
    "docker",
    "claude",
    "lm-studio",
    "typescript"
  ],
  "author": "Axyor",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22 <23"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.4",
    "@types/sanitize-html": "^2.16.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "js-yaml": "^5.1.0"
  },
  "dependencies": {
    "@axyor/family-serve-database": "^2.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "rotating-file-stream": "^3.2.9",
    "sanitize-html": "^2.17.5",
    "zod": "^4.4.3"
  }
}
